---
const year = new Date().getFullYear();
---
<footer class="border-t font-display" style="border-color: oklch(0.88 0.012 80); background: oklch(0.965 0.010 80);">

  <div class="max-w-7xl mx-auto px-5 sm:px-8 lg:px-12 py-14">

    <div class="grid grid-cols-1 md:grid-cols-4 gap-10 mb-12">

      <!-- Brand column -->
      <div class="md:col-span-2">
        <div class="flex items-center gap-2.5 mb-4">
          <span class="w-7 h-7 rounded-lg flex items-center justify-center text-white text-sm"
                style="background: oklch(0.47 0.13 155);">
            <svg xmlns="http://www.w3.org/2000/svg" class="w-4 h-4" fill="none" viewBox="0 0 24 24" stroke-width="2.2" stroke="currentColor">
              <path stroke-linecap="round" stroke-linejoin="round" d="M12 3c4.97 0 9 4.03 9 9s-4.03 9-9 9-9-4.03-9-9c0-2.76 1.24-5.23 3.2-6.93M12 3v12" />
            </svg>
          </span>
          <span class="text-base font-bold tracking-tight text-surface-900">Sideline</span>
        </div>
        <p class="text-sm text-surface-800/55 leading-relaxed max-w-xs font-body">
          Everything your kids do, all in one place. Built by parents, for parents.
        </p>
        <div class="flex gap-3 mt-5">
          <!-- App store badges (placeholder links) -->
          <a href="#" class="inline-flex items-center gap-1.5 px-3 py-1.5 rounded-lg text-xs font-semibold text-surface-900 transition-colors hover:bg-surface-200"
             style="background:#fff; border: 1px solid oklch(0.88 0.012 80);">
            <svg class="w-4 h-4" viewBox="0 0 24 24" fill="currentColor"><path d="M18.71 19.5c-.83 1.24-1.71 2.45-3.05 2.47-1.34.03-1.77-.79-3.29-.79-1.53 0-2 .77-3.27.82-1.31.05-2.3-1.32-3.14-2.53C4.25 17 2.94 12.45 4.7 9.39c.87-1.52 2.43-2.48 4.12-2.51 1.28-.02 2.5.87 3.29.87.78 0 2.26-1.07 3.8-.91.65.03 2.47.26 3.64 1.98-.09.06-2.17 1.28-2.15 3.81.03 3.02 2.65 4.03 2.68 4.04-.03.07-.42 1.44-1.38 2.83M13 3.5c.73-.83 1.94-1.46 2.94-1.5.13 1.17-.34 2.35-1.04 3.19-.69.85-1.83 1.51-2.95 1.42-.15-1.15.41-2.35 1.05-3.11z"/></svg>
            App Store
          </a>
          <a href="#" class="inline-flex items-center gap-1.5 px-3 py-1.5 rounded-lg text-xs font-semibold text-surface-900 transition-colors hover:bg-surface-200"
             style="background:#fff; border: 1px solid oklch(0.88 0.012 80);">
            <svg class="w-4 h-4" viewBox="0 0 24 24" fill="currentColor"><path d="M3.18 23.76c.3.17.64.24.99.2l12.6-12.6-2.52-2.52L3.18 23.76zM20.6 10.59l-2.44-1.4-2.8 2.81 2.8 2.8 2.44-1.4a1.68 1.68 0 000-2.81zM2 1.05a1.7 1.7 0 00-.24.9v20.1c0 .34.09.65.24.9l.1.09 11.25-11.25v-.27L2.1.96 2 1.05zm3.02 21.67l10.35-10.37-2.52-2.52L3.02 19.74c-.1.32-.1.66 0 .98l2 2z"/></svg>
            Google Play
          </a>
        </div>
      </div>

      <!-- Links -->
      <div>
        <h4 class="text-xs font-bold uppercase tracking-widest text-surface-800/40 mb-4">Product</h4>
        <ul class="space-y-2.5">
          {['Features', 'Pricing', 'How it works', 'For families', 'iOS app', 'Android app'].map(link => (
            <li><a href="#" class="text-sm text-surface-800/60 hover:text-surface-900 transition-colors">{link}</a></li>
          ))}
        </ul>
      </div>

      <div>
        <h4 class="text-xs font-bold uppercase tracking-widest text-surface-800/40 mb-4">Company</h4>
        <ul class="space-y-2.5">
          {['About', 'Blog', 'Privacy policy', 'Terms of service', 'Contact'].map(link => (
            <li><a href="#" class="text-sm text-surface-800/60 hover:text-surface-900 transition-colors">{link}</a></li>
          ))}
        </ul>
      </div>

    </div>

    <!-- Bottom bar -->
    <div class="flex flex-col md:flex-row md:items-center justify-between gap-3 pt-8" style="border-top: 1px solid oklch(0.88 0.012 80);">
      <p class="text-xs text-surface-800/40">&copy; {year} Sideline. All rights reserved.</p>
      <p class="text-xs text-surface-800/35 font-body italic">Built for the parents on the sideline. ⚽</p>
    </div>

  </div>

</footer>
