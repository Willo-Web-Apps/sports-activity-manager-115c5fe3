---
---
<header class="sticky top-0 z-50 border-b font-display"
        style="border-color: oklch(0.88 0.012 80); background: oklch(0.985 0.008 80 / 0.88); backdrop-filter: blur(16px) saturate(1.2);">
  <nav class="max-w-7xl mx-auto px-5 sm:px-8 lg:px-12 h-16 flex items-center justify-between">

    <!-- Logo mark + wordmark -->
    <a href="/" class="flex items-center gap-2.5 group">
      <!-- Leaf icon mark -->
      <span class="w-7 h-7 rounded-lg flex items-center justify-center text-white text-sm flex-shrink-0"
            style="background: oklch(0.47 0.13 155);">
        <svg xmlns="http://www.w3.org/2000/svg" class="w-4 h-4" fill="none" viewBox="0 0 24 24" stroke-width="2.2" stroke="currentColor">
          <path stroke-linecap="round" stroke-linejoin="round"
                d="M12 3c4.97 0 9 4.03 9 9s-4.03 9-9 9-9-4.03-9-9c0-2.76 1.24-5.23 3.2-6.93M12 3v12" />
        </svg>
      </span>
      <span class="text-base font-bold tracking-tight text-surface-900">Sideline</span>
    </a>

    <!-- Nav links -->
    <div class="hidden md:flex items-center gap-7">
      <a href="#features" class="text-sm font-medium text-surface-800/60 hover:text-surface-900 transition-colors">Features</a>
      <a href="#" class="text-sm font-medium text-surface-800/60 hover:text-surface-900 transition-colors">Pricing</a>
      <a href="/blog" class="text-sm font-medium text-surface-800/60 hover:text-surface-900 transition-colors">Blog</a>
    </div>

    <!-- CTA -->
    <div class="flex items-center gap-3">
      <a href="#" class="hidden sm:inline text-sm font-semibold text-surface-800/65 hover:text-surface-900 transition-colors">Sign in</a>
      <a href="#get-started"
         class="text-sm font-semibold px-4 py-2 rounded-lg text-white transition-all duration-150 hover:scale-[1.03]"
         style="background: oklch(0.47 0.13 155);">
        Start free
      </a>
    </div>

  </nav>
</header>
