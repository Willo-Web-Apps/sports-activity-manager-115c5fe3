---
import Base from '../layouts/Base.astro';
---
<Base title="KidFlow — Family Activity Hub" description="KidFlow unites every practice, game, recital, and class into one beautiful family dashboard — built for parents, not coaches.">

  <!-- =====================================================================
       HERO — Asymmetric layout: left text + right dashboard visual
       ===================================================================== -->
  <section class="relative min-h-[92vh] flex items-center overflow-hidden bg-[#FAF6F1]">

    <!-- Background gradient orbs (forest morning light) -->
    <div class="absolute inset-0 pointer-events-none" aria-hidden="true">
      <!-- Primary green glow — upper left -->
      <div style="
        position:absolute; inset:0;
        background: radial-gradient(ellipse 70% 60% at -10% 20%, oklch(0.47 0.13 155 / 0.13) 0%, transparent 70%);
      "></div>
      <!-- Warm orange glow — lower right -->
      <div style="
        position:absolute; inset:0;
        background: radial-gradient(ellipse 55% 50% at 105% 85%, oklch(0.67 0.17 50 / 0.14) 0%, transparent 65%);
      "></div>
      <!-- Subtle warm fill — center -->
      <div style="
        position:absolute; inset:0;
        background: radial-gradient(ellipse 80% 40% at 50% 0%, oklch(0.86 0.07 155 / 0.07) 0%, transparent 60%);
      "></div>
      <!-- Noise texture overlay -->
      <div class="hero-noise" aria-hidden="true"></div>
    </div>

    <div class="relative z-10 max-w-7xl mx-auto px-5 sm:px-8 lg:px-12 py-20 md:py-28 w-full">
      <div class="grid lg:grid-cols-2 gap-14 lg:gap-8 items-center">

        <!-- Left: Copy -->
        <div class="max-w-xl">
          <!-- Eyebrow -->
          <p class="animate-fade-in inline-flex items-center gap-2 text-sm font-semibold tracking-wide uppercase mb-5 font-display" style="color:oklch(0.57 0.16 50);">
            <span style="display:inline-block;width:28px;height:2px;background:oklch(0.57 0.16 50);border-radius:2px;flex-shrink:0;"></span>
            Built for parents, not coaches
          </p>

          <h1 class="animate-slide-up font-display text-5xl md:text-6xl lg:text-[3.6rem] xl:text-[4rem] font-bold leading-[1.08] tracking-tight text-surface-900">
            Stop juggling.<br/>
            <span style="color: oklch(0.47 0.13 155);">Start winning</span><br/>
            the week together.
          </h1>

          <p class="animate-slide-up delay-100 mt-6 text-lg md:text-xl font-body text-surface-800/75 leading-relaxed max-w-lg">
            KidFlow unites every practice, game, recital, and class into one beautiful family dashboard — built for parents, not coaches.
          </p>

          <!-- CTA row -->
          <div class="animate-slide-up delay-200 mt-9 flex flex-col sm:flex-row items-start sm:items-center gap-4">
            <a href="#get-started"
               class="inline-block px-7 py-3.5 rounded-xl font-semibold font-display text-base text-white transition-all duration-200 hover:scale-[1.03] active:scale-[0.98]"
               style="background: oklch(0.47 0.13 155); box-shadow: 0 4px 18px oklch(0.47 0.13 155 / 0.30);">
              Organize my family — free
            </a>
            <a href="#features"
               class="inline-flex items-center gap-2 text-sm font-semibold font-display text-surface-800 hover:text-surface-900 transition-colors">
              See how it works
              <svg xmlns="http://www.w3.org/2000/svg" class="w-4 h-4" fill="none" viewBox="0 0 24 24" stroke-width="2" stroke="currentColor">
                <path stroke-linecap="round" stroke-linejoin="round" d="M17.25 8.25 21 12m0 0-3.75 3.75M21 12H3" />
              </svg>
            </a>
          </div>

          <!-- Micro-proof -->
          <p class="animate-fade-in delay-300 mt-5 text-sm text-surface-800/50 font-display">
            No credit card required &nbsp;·&nbsp; Free 30-day trial &nbsp;·&nbsp; Cancel anytime
          </p>
        </div>

        <!-- Right: Product visual — CSS dashboard mockup -->
        <div class="animate-fade-in delay-200 relative flex justify-center lg:justify-end">
          <div class="animate-float relative w-full max-w-[430px]" style="filter: drop-shadow(0 24px 48px oklch(0.22 0.028 145 / 0.15));">

            <!-- Dashboard card shell -->
            <div class="rounded-2xl overflow-hidden" style="background:#fff; border: 1px solid oklch(0.88 0.012 80);">

              <!-- Top bar -->
              <div class="px-5 py-4 flex items-center justify-between" style="background: oklch(0.47 0.13 155);">
                <div class="flex items-center gap-2">
                  <span class="w-2 h-2 rounded-full bg-white/40"></span>
                  <span class="text-sm font-semibold text-white font-display">KidFlow</span>
                </div>
                <span class="text-xs text-white/70 font-display">This Week</span>
              </div>

              <!-- Week row pills -->
              <div class="px-5 pt-4 pb-2 flex gap-2 overflow-x-auto">
                {['Mon','Tue','Wed','Thu','Fri','Sat','Sun'].map((d, i) => (
                  <div class={`flex-shrink-0 flex flex-col items-center gap-1 px-3 py-2 rounded-xl text-xs font-semibold font-display transition-colors ${i===2 ? 'text-white' : 'text-surface-800/60'}`}
                       style={i===2 ? 'background:oklch(0.67 0.17 50);' : 'background:oklch(0.965 0.010 80);'}>
                    <span>{d}</span>
                    {i===2 && <span class="w-1.5 h-1.5 rounded-full bg-white/80"></span>}
                  </div>
                ))}
              </div>

              <!-- Activity cards -->
              <div class="px-5 py-4 flex flex-col gap-3">

                <!-- Kid row label -->
                <div class="flex items-center gap-2 mb-1">
                  <span class="w-6 h-6 rounded-full text-xs font-bold text-white flex items-center justify-center font-display" style="background:oklch(0.47 0.13 155);">E</span>
                  <span class="text-xs font-semibold text-surface-800/60 font-display uppercase tracking-wide">Emma · 3 activities</span>
                </div>

                <!-- Activity card 1 -->
                <div class="flex items-center gap-3 rounded-xl px-4 py-3" style="background:oklch(0.93 0.04 155 / 0.4); border-left: 3px solid oklch(0.47 0.13 155);">
                  <div class="text-lg">⚽</div>
                  <div class="flex-1 min-w-0">
                    <p class="text-sm font-semibold text-surface-900 font-display truncate">Soccer Practice</p>
                    <p class="text-xs text-surface-800/55 font-display">4:30 PM · Riverside Park, Field 3</p>
                  </div>
                  <span class="text-xs font-semibold px-2 py-0.5 rounded-full font-display" style="background:oklch(0.47 0.13 155);color:#fff;">Today</span>
                </div>

                <!-- Activity card 2 -->
                <div class="flex items-center gap-3 rounded-xl px-4 py-3" style="background:oklch(0.97 0.03 50 / 0.4); border-left: 3px solid oklch(0.67 0.17 50);">
                  <div class="text-lg">🎹</div>
                  <div class="flex-1 min-w-0">
                    <p class="text-sm font-semibold text-surface-900 font-display truncate">Piano Lesson</p>
                    <p class="text-xs text-surface-800/55 font-display">6:00 PM · Ms. Chen's Studio</p>
                  </div>
                  <span class="text-xs font-semibold px-2 py-0.5 rounded-full font-display" style="background:oklch(0.87 0.11 50);color:oklch(0.38 0.12 50);">Wed</span>
                </div>

                <!-- Divider -->
                <div class="flex items-center gap-2 mt-1">
                  <span class="w-6 h-6 rounded-full text-xs font-bold text-white flex items-center justify-center font-display" style="background:oklch(0.67 0.17 50);">L</span>
                  <span class="text-xs font-semibold text-surface-800/60 font-display uppercase tracking-wide">Liam · 2 activities</span>
                </div>

                <!-- Activity card 3 -->
                <div class="flex items-center gap-3 rounded-xl px-4 py-3" style="background:oklch(0.97 0.018 155 / 0.5); border-left: 3px solid oklch(0.60 0.12 155);">
                  <div class="text-lg">🏊</div>
                  <div class="flex-1 min-w-0">
                    <p class="text-sm font-semibold text-surface-900 font-display truncate">Swim Team</p>
                    <p class="text-xs text-surface-800/55 font-display">5:00 PM · Community Aquatic Center</p>
                  </div>
                  <span class="text-xs font-semibold px-2 py-0.5 rounded-full font-display" style="background:oklch(0.965 0.010 80);color:oklch(0.38 0.12 155);">Thu</span>
                </div>

              </div>

              <!-- Bottom bar -->
              <div class="px-5 py-3 flex items-center justify-between" style="border-top: 1px solid oklch(0.93 0.012 80);">
                <span class="text-xs text-surface-800/50 font-display">3 kids · 7 activities this week</span>
                <span class="text-xs font-semibold font-display" style="color:oklch(0.47 0.13 155);">View all →</span>
              </div>

            </div>

            <!-- Floating badge — notification style -->
            <div class="absolute -top-4 -right-4 rounded-2xl px-4 py-2.5 shadow-lg flex items-center gap-2.5"
                 style="background:#fff; border: 1px solid oklch(0.93 0.012 80);">
              <span class="text-base">📍</span>
              <div>
                <p class="text-xs font-bold text-surface-900 font-display leading-tight">Game day reminder</p>
                <p class="text-xs text-surface-800/55 font-display">Saturday 9:00 AM</p>
              </div>
            </div>

          </div>
        </div>

      </div>
    </div>
  </section>

  <!-- =====================================================================
       SOCIAL PROOF BAR — parent stats
       ===================================================================== -->
  <section class="py-10 border-y" style="border-color: oklch(0.88 0.012 80); background: oklch(0.965 0.010 80);">
    <div class="max-w-6xl mx-auto px-5 sm:px-8">
      <div class="grid grid-cols-2 md:grid-cols-4 gap-8 text-center">
        {[
          { num: "14,000+", label: "families organized" },
          { num: "3.2",     label: "average kids per family" },
          { num: "6 apps",  label: "replaced on average" },
          { num: "4.9 ★",  label: "parent rating" },
        ].map(stat => (
          <div>
            <p class="text-3xl md:text-4xl font-bold font-display" style="color:oklch(0.47 0.13 155);">{stat.num}</p>
            <p class="mt-1 text-sm text-surface-800/60 font-display">{stat.label}</p>
          </div>
        ))}
      </div>
    </div>
  </section>

  <!-- =====================================================================
       FEATURE DEEP-DIVES — alternating left/right
       ===================================================================== -->
  <section id="features" class="py-24 md:py-32 bg-[#FAF6F1]">
    <div class="max-w-6xl mx-auto px-5 sm:px-8">

      <!-- Section intro -->
      <div class="text-center max-w-2xl mx-auto mb-20">
        <p class="text-sm font-semibold font-display uppercase tracking-widest mb-3" style="color:oklch(0.67 0.17 50);">How KidFlow works</p>
        <h2 class="text-4xl md:text-5xl font-bold font-display text-surface-900 leading-tight">
          One place. Every kid.<br/>All the chaos, solved.
        </h2>
        <p class="mt-5 text-lg font-body text-surface-800/65 leading-relaxed">
          No more toggling between six apps, hunting for practice schedules, or missing a reminder because it got buried in a group chat.
        </p>
      </div>

      <!-- Feature 1: All kids, one view -->
      <div class="grid md:grid-cols-2 gap-12 lg:gap-20 items-center mb-24">
        <div>
          <span class="inline-block text-4xl mb-5">👨‍👩‍👧‍👦</span>
          <h3 class="text-3xl font-bold font-display text-surface-900 leading-tight mb-4">
            Every kid on one dashboard — no switching required
          </h3>
          <p class="text-lg font-body text-surface-800/65 leading-relaxed mb-6">
            See Emma's soccer, Liam's swim, and Maya's dance all on one screen. Filter by day, by child, or by activity type. Finally, a view that works for <em>your</em> family.
          </p>
          <ul class="space-y-3">
            {[
              "Color-coded by child for instant recognition",
              "Week and month views that actually make sense",
              "Instant conflict detection — no more double-bookings",
            ].map(item => (
              <li class="flex items-start gap-3 text-sm font-display text-surface-800/75">
                <svg class="w-5 h-5 flex-shrink-0 mt-0.5" style="color:oklch(0.47 0.13 155);" fill="none" viewBox="0 0 24 24" stroke-width="2.5" stroke="currentColor">
                  <path stroke-linecap="round" stroke-linejoin="round" d="m4.5 12.75 6 6 9-13.5" />
                </svg>
                {item}
              </li>
            ))}
          </ul>
        </div>
        <!-- Visual: multi-kid mini calendar -->
        <div class="rounded-2xl p-6" style="background:#fff; border: 1px solid oklch(0.88 0.012 80); box-shadow: 0 8px 32px oklch(0.22 0.028 145 / 0.06);">
          <div class="flex items-center justify-between mb-5">
            <span class="font-bold text-sm font-display text-surface-900">This Week</span>
            <div class="flex gap-2">
              {['E','L','M'].map((init, i) => (
                <span class="w-6 h-6 rounded-full text-xs font-bold text-white flex items-center justify-center font-display"
                      style={`background:${i===0?'oklch(0.47 0.13 155)':i===1?'oklch(0.67 0.17 50)':'oklch(0.60 0.12 155)'}`}>{init}</span>
              ))}
            </div>
          </div>
          {[
            { day:'Mon', items:[{kid:'E',color:'oklch(0.47 0.13 155)',label:'Soccer 4:30 PM'}] },
            { day:'Tue', items:[{kid:'L',color:'oklch(0.67 0.17 50)',label:'Swim 5:00 PM'},{kid:'M',color:'oklch(0.60 0.12 155)',label:'Dance 6:30 PM'}] },
            { day:'Wed', items:[{kid:'E',color:'oklch(0.47 0.13 155)',label:'Piano 6:00 PM'}] },
            { day:'Thu', items:[{kid:'E',color:'oklch(0.47 0.13 155)',label:'Soccer 4:30 PM'},{kid:'L',color:'oklch(0.67 0.17 50)',label:'Swim 5:00 PM'}] },
            { day:'Sat', items:[{kid:'E',color:'oklch(0.47 0.13 155)',label:'⚽ Game 9:00 AM'},{kid:'M',color:'oklch(0.60 0.12 155)',label:'Recital 2:00 PM'}] },
          ].map(row => (
            <div class="flex items-start gap-3 py-2.5" style="border-top: 1px solid oklch(0.93 0.012 80);">
              <span class="text-xs font-bold font-display text-surface-800/40 w-6 flex-shrink-0 mt-1">{row.day}</span>
              <div class="flex flex-wrap gap-2 flex-1">
                {row.items.map(item => (
                  <span class="text-xs font-semibold font-display px-2.5 py-1 rounded-lg text-white" style={`background:${item.color};`}>{item.label}</span>
                ))}
              </div>
            </div>
          ))}
        </div>
      </div>

      <!-- Feature 2: Smart reminders (reverse) -->
      <div class="grid md:grid-cols-2 gap-12 lg:gap-20 items-center mb-24">
        <!-- Visual: notification stack -->
        <div class="order-2 md:order-1 rounded-2xl p-6 relative" style="background:#fff; border: 1px solid oklch(0.88 0.012 80); box-shadow: 0 8px 32px oklch(0.22 0.028 145 / 0.06);">
          <p class="text-xs font-bold font-display uppercase tracking-widest text-surface-800/40 mb-4">Smart Reminders</p>
          {[
            { icon:'⚽', title:"Emma's soccer gear reminder", sub:"Pack cleats + shin guards · 2 hrs before practice", color:'oklch(0.47 0.13 155)', bg:'oklch(0.93 0.04 155 / 0.45)', time:'2h before' },
            { icon:'🚗', title:"Drive time alert", sub:"Leave by 4:05 PM to reach Riverside Park on time", color:'oklch(0.57 0.16 50)', bg:'oklch(0.87 0.11 50 / 0.35)', time:'55 min before' },
            { icon:'💰', title:"Swim team payment due", sub:"$45 monthly fee due Friday — pay in app", color:'oklch(0.47 0.13 155)', bg:'oklch(0.93 0.04 155 / 0.45)', time:'3 days before' },
            { icon:'📋', title:"Permission slip needed", sub:"Dance recital form due Wednesday", color:'oklch(0.57 0.16 50)', bg:'oklch(0.87 0.11 50 / 0.35)', time:'5 days before' },
          ].map(n => (
            <div class="flex items-start gap-3 py-3" style="border-bottom: 1px solid oklch(0.965 0.010 80);">
              <span class="text-xl flex-shrink-0">{n.icon}</span>
              <div class="flex-1 min-w-0">
                <p class="text-sm font-semibold font-display text-surface-900 leading-tight">{n.title}</p>
                <p class="text-xs font-body text-surface-800/55 mt-0.5 leading-snug">{n.sub}</p>
              </div>
              <span class="text-xs font-semibold font-display flex-shrink-0 px-2 py-0.5 rounded-full" style={`color:${n.color};background:${n.bg}`}>{n.time}</span>
            </div>
          ))}
        </div>
        <div class="order-1 md:order-2">
          <span class="inline-block text-4xl mb-5">🔔</span>
          <h3 class="text-3xl font-bold font-display text-surface-900 leading-tight mb-4">
            Reminders that actually know what you need
          </h3>
          <p class="text-lg font-body text-surface-800/65 leading-relaxed mb-6">
            KidFlow sends the right nudge at the right time — pack reminders, drive-time alerts, fee due dates, and permission slip warnings. No setup, no fiddling.
          </p>
          <ul class="space-y-3">
            {[
              "Location-aware drive time estimates",
              "Gear checklists per activity type",
              "Payment and permission slip tracking",
            ].map(item => (
              <li class="flex items-start gap-3 text-sm font-display text-surface-800/75">
                <svg class="w-5 h-5 flex-shrink-0 mt-0.5" style="color:oklch(0.47 0.13 155);" fill="none" viewBox="0 0 24 24" stroke-width="2.5" stroke="currentColor">
                  <path stroke-linecap="round" stroke-linejoin="round" d="m4.5 12.75 6 6 9-13.5" />
                </svg>
                {item}
              </li>
            ))}
          </ul>
        </div>
      </div>

      <!-- Feature 3: Family sharing -->
      <div class="grid md:grid-cols-2 gap-12 lg:gap-20 items-center">
        <div>
          <span class="inline-block text-4xl mb-5">🤝</span>
          <h3 class="text-3xl font-bold font-display text-surface-900 leading-tight mb-4">
            Share the load — not the confusion
          </h3>
          <p class="text-lg font-body text-surface-800/65 leading-relaxed mb-6">
            Invite your co-parent, grandparents, or carpool partners. Everyone sees the same live schedule. No more "I thought you were picking them up" moments.
          </p>
          <ul class="space-y-3">
            {[
              "Up to 6 family members per account",
              "Carpool coordination built right in",
              "Shared notes per event — no group chat chaos",
            ].map(item => (
              <li class="flex items-start gap-3 text-sm font-display text-surface-800/75">
                <svg class="w-5 h-5 flex-shrink-0 mt-0.5" style="color:oklch(0.47 0.13 155);" fill="none" viewBox="0 0 24 24" stroke-width="2.5" stroke="currentColor">
                  <path stroke-linecap="round" stroke-linejoin="round" d="m4.5 12.75 6 6 9-13.5" />
                </svg>
                {item}
              </li>
            ))}
          </ul>
        </div>
        <!-- Visual: sharing avatars -->
        <div class="rounded-2xl p-7" style="background:#fff; border: 1px solid oklch(0.88 0.012 80); box-shadow: 0 8px 32px oklch(0.22 0.028 145 / 0.06);">
          <p class="text-sm font-bold font-display text-surface-900 mb-5">The Thompson family</p>
          <div class="space-y-4">
            {[
              { name:'Sarah (you)', role:'Primary parent', color:'oklch(0.47 0.13 155)', badge:'Admin' },
              { name:'Mike',        role:'Co-parent',       color:'oklch(0.60 0.12 155)', badge:'Editor' },
              { name:'Grandma Sue', role:'Pickup help',     color:'oklch(0.67 0.17 50)', badge:'Viewer' },
              { name:'Carpool — Jen',role:'Wed pickup',     color:'oklch(0.74 0.16 50)', badge:'Limited' },
            ].map(person => (
              <div class="flex items-center gap-3 p-3 rounded-xl" style="background:oklch(0.985 0.008 80);">
                <span class="w-9 h-9 rounded-full text-sm font-bold text-white flex items-center justify-center font-display flex-shrink-0" style={`background:${person.color};`}>{person.name[0]}</span>
                <div class="flex-1 min-w-0">
                  <p class="text-sm font-semibold font-display text-surface-900 truncate">{person.name}</p>
                  <p class="text-xs font-body text-surface-800/50">{person.role}</p>
                </div>
                <span class="text-xs font-semibold font-display px-2.5 py-1 rounded-full" style="background:oklch(0.93 0.04 155 / 0.5);color:oklch(0.38 0.12 155);">{person.badge}</span>
              </div>
            ))}
          </div>
          <div class="mt-5 flex items-center gap-2 text-xs font-display text-surface-800/50">
            <svg class="w-4 h-4 flex-shrink-0" style="color:oklch(0.47 0.13 155);" fill="none" viewBox="0 0 24 24" stroke-width="2" stroke="currentColor">
              <path stroke-linecap="round" stroke-linejoin="round" d="M16.5 10.5V6.75a4.5 4.5 0 1 0-9 0v3.75m-.75 11.25h10.5a2.25 2.25 0 0 0 2.25-2.25v-6.75a2.25 2.25 0 0 0-2.25-2.25H6.75a2.25 2.25 0 0 0-2.25 2.25v6.75a2.25 2.25 0 0 0 2.25 2.25z" />
            </svg>
            All access is permission-controlled, always.
          </div>
        </div>
      </div>

    </div>
  </section>

  <!-- =====================================================================
       WORKS FOR EVERY ACTIVITY — organic pill grid
       ===================================================================== -->
  <section class="py-20 md:py-28 relative overflow-hidden" style="background: oklch(0.47 0.13 155);">
    <!-- Subtle warm texture -->
    <div class="absolute inset-0 pointer-events-none" aria-hidden="true" style="
      background: radial-gradient(ellipse 60% 80% at 90% 110%, oklch(0.67 0.17 50 / 0.18) 0%, transparent 60%),
                  radial-gradient(ellipse 50% 60% at 5% -10%, oklch(0.86 0.07 155 / 0.25) 0%, transparent 55%);
    "></div>

    <div class="relative z-10 max-w-5xl mx-auto px-5 sm:px-8 text-center">
      <p class="text-sm font-semibold font-display uppercase tracking-widest mb-3" style="color:oklch(0.87 0.07 80);">Not just sports</p>
      <h2 class="text-4xl md:text-5xl font-bold font-display text-white leading-tight mb-4">
        Works for every activity your kids do
      </h2>
      <p class="text-lg font-body mb-12" style="color:oklch(0.93 0.04 155);">
        While TeamSnap is for coaches, KidFlow is for families. Dance, drama, chess club — KidFlow handles it all.
      </p>

      <div class="flex flex-wrap gap-3 justify-center">
        {[
          '⚽ Soccer','🏊 Swim','🎹 Piano','💃 Dance','🏀 Basketball',
          '🎭 Theater','🏋️ Gymnastics','⚾ Baseball','🎨 Art class','🤼 Wrestling',
          '🎸 Guitar','🏑 Field Hockey','♟️ Chess Club','🥋 Karate','🎺 Band',
          '🏈 Football','🎻 Violin','🧗 Rock Climbing','📚 Tutoring','🎯 Archery',
        ].map(act => (
          <span class="px-4 py-2 rounded-full text-sm font-semibold font-display text-white transition-all duration-150 cursor-default hover:scale-105"
                style="background: oklch(1 0 0 / 0.12); border: 1px solid oklch(1 0 0 / 0.18); backdrop-filter: blur(4px);">
            {act}
          </span>
        ))}
      </div>
    </div>
  </section>

  <!-- =====================================================================
       TESTIMONIALS — parent voices
       ===================================================================== -->
  <section class="py-24 md:py-32 bg-[#FAF6F1]">
    <div class="max-w-6xl mx-auto px-5 sm:px-8">

      <div class="text-center max-w-2xl mx-auto mb-16">
